{
  "name": "推送到 MakerHub",
  "share_sheet": {
    "enabled": true,
    "accepts": ["文件"]
  },
  "variables": {
    "MakerHubToken": "在 MakerHub 设置 -> 本地整理 -> 移动端导入里生成",
    "MakerHubBaseUrl": ""
  },
  "flow": [
    {
      "action": "接收共享表单输入",
      "input": "快捷指令输入"
    },
    {
      "action": "获取 URL 内容",
      "method": "GET",
      "url": "${MakerHubBaseUrl}/api/mobile-import/ping-ipv4?token=${MakerHubToken}",
      "expect": "makerhub:ok"
    },
    {
      "action": "获取名称",
      "input": "快捷指令输入",
      "sets": {
        "FileName": "获取名称的结果"
      }
    },
    {
      "action": "获取 URL 内容",
      "method": "POST",
      "url": "${MakerHubBaseUrl}/api/mobile-import/raw-ipv4?token=${MakerHubToken}&filename=${FileName}",
      "headers": {
        "X-MakerHub-Filename": "${FileName}"
      },
      "request_body": "文件",
      "file": "快捷指令输入"
    },
    {
      "action": "显示通知",
      "text": "已上传"
    }
  ],
  "makerhub_endpoints": {
    "probe": "/api/mobile-import/ping-ipv4?token=...",
    "upload": "/api/mobile-import/raw-ipv4?token=...&filename=..."
  },
  "network_rule": "在 MakerHub 地址里填写当前手机能访问的局域网或公网地址；地址不可用时由 iOS 显示请求失败。"
}
